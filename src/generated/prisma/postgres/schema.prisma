  enabled            Int     @default(1)
  entity_type        String
  condition_field    String
  condition_operator String
  condition_value    String
  action_type        String  @default("notification")
  action_config      String  @default("{}")
  cooldown_minutes   Int     @default(60)
  last_triggered_at  Int?
  trigger_count      Int     @default(0)
  created_by         String  @default("system")
  created_at         Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at         Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  workspace_id       Int     @default(1)

  @@index([workspace_id], map: "idx_alert_rules_workspace_id")
  @@index([entity_type], map: "idx_alert_rules_entity_type")
  @@index([enabled], map: "idx_alert_rules_enabled")
}

model api_keys {
  id           Int     @id @default(autoincrement())
  user_id      Int
  label        String
  key_prefix   String
  key_hash     String  @unique(map: "sqlite_autoindex_api_keys_1")
  role         String  @default("viewer")
  scopes       String?
  expires_at   Int?
  last_used_at Int?
  last_used_ip String?
  workspace_id Int     @default(1)
  tenant_id    Int     @default(1)
  is_revoked   Int     @default(0)
  created_at   Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at   Int     @default(dbgenerated("floor(extract(epoch from now()))"))

  @@index([key_prefix], map: "idx_api_keys_prefix")
  @@index([workspace_id], map: "idx_api_keys_workspace_id")
  @@index([user_id], map: "idx_api_keys_user_id")
  @@index([key_hash], map: "idx_api_keys_key_hash")
}

model audit_log {
  id          Int     @id @default(autoincrement())
  action      String
  actor       String
  actor_id    Int?
  target_type String?
  target_id   Int?
  detail      String?
  ip_address  String?
  user_agent  String?
  created_at  Int     @default(dbgenerated("floor(extract(epoch from now()))"))

  @@index([created_at], map: "idx_audit_log_created_at")
  @@index([actor], map: "idx_audit_log_actor")
  @@index([action], map: "idx_audit_log_action")
}

model claude_sessions {
  id                 Int     @id @default(autoincrement())
  session_id         String  @unique(map: "sqlite_autoindex_claude_sessions_1")
  project_slug       String
  project_path       String?
  model              String?
  git_branch         String?
  user_messages      Int     @default(0)
  assistant_messages Int     @default(0)
  tool_uses          Int     @default(0)
  input_tokens       Int     @default(0)
  output_tokens      Int     @default(0)
  estimated_cost     Float   @default(0)
  first_message_at   String?
  last_message_at    String?
  last_user_prompt   String?
  is_active          Int     @default(0)
  scanned_at         Int
  created_at         Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at         Int     @default(dbgenerated("floor(extract(epoch from now()))"))

  @@index([project_slug], map: "idx_claude_sessions_project")
  @@index([is_active], map: "idx_claude_sessions_active", where: raw("is_active = 1"))
}

model comments {
  id             Int        @id @default(autoincrement())
  task_id        Int
  author         String
  content        String
  created_at     Int        @default(dbgenerated("floor(extract(epoch from now()))"))
  parent_id      Int?
  mentions       String?
  workspace_id   Int        @default(1)
  comments       comments?  @relation("commentsTocomments", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_comments comments[] @relation("commentsTocomments")
  tasks          tasks      @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workspace_id], map: "idx_comments_workspace_id")
  @@index([created_at], map: "idx_comments_created_at")
  @@index([task_id], map: "idx_comments_task_id")
}

model direct_connections {
  id             Int     @id @default(autoincrement())
  agent_id       Int
  tool_name      String
  tool_version   String?
  connection_id  String  @unique(map: "sqlite_autoindex_direct_connections_1")
  status         String  @default("connected")
  last_heartbeat Int?
  metadata       String?
  created_at     Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at     Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  workspace_id   Int     @default(1)
  agents         agents  @relation(fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workspace_id], map: "idx_direct_connections_workspace_id")
  @@index([status], map: "idx_direct_connections_status")
  @@index([connection_id], map: "idx_direct_connections_connection_id")
  @@index([agent_id], map: "idx_direct_connections_agent_id")
}

model eval_golden_sets {
