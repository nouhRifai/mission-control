  id             Int              @id @default(autoincrement())
  slug           String           @unique(map: "sqlite_autoindex_tenants_1")
  display_name   String
  linux_user     String           @unique(map: "sqlite_autoindex_tenants_2")
  plan_tier      String           @default("standard")
  status         String           @default("pending")
  openclaw_home  String
  workspace_root String
  gateway_port   Int?
  dashboard_port Int?
  config         String           @default("{}")
  created_by     String           @default("system")
  created_at     Int              @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at     Int              @default(dbgenerated("floor(extract(epoch from now()))"))
  owner_gateway  String?
  provision_jobs provision_jobs[]
  workspaces     workspaces[]

  @@index([owner_gateway], map: "idx_tenants_owner_gateway")
  @@index([status], map: "idx_tenants_status")
  @@index([slug], map: "idx_tenants_slug")
}

model token_usage {
  id            Int     @id @default(autoincrement())
  model         String
  session_id    String
  input_tokens  Int     @default(0)
  output_tokens Int     @default(0)
  created_at    Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  workspace_id  Int     @default(1)
  task_id       Int?
  cost_usd      Float?
  agent_name    String?

  @@index([workspace_id, task_id, created_at], map: "idx_token_usage_workspace_task_time")
  @@index([task_id], map: "idx_token_usage_task_id")
  @@index([workspace_id], map: "idx_token_usage_workspace_id")
  @@index([model], map: "idx_token_usage_model")
  @@index([created_at], map: "idx_token_usage_created_at")
  @@index([session_id], map: "idx_token_usage_session_id")
}

model user_sessions {
  id           Int     @id @default(autoincrement())
  token        String  @unique(map: "sqlite_autoindex_user_sessions_1")
  user_id      Int
  expires_at   Int
  created_at   Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  ip_address   String?
  user_agent   String?
  workspace_id Int     @default(1)
  tenant_id    Int?
  users        users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workspace_id, tenant_id], map: "idx_user_sessions_workspace_tenant")
  @@index([tenant_id], map: "idx_user_sessions_tenant_id")
  @@index([workspace_id], map: "idx_user_sessions_workspace_id")
  @@index([expires_at], map: "idx_user_sessions_expires_at")
  @@index([user_id], map: "idx_user_sessions_user_id")
  @@index([token], map: "idx_user_sessions_token")
}

model users {
  id               Int               @id @default(autoincrement())
  username         String            @unique(map: "sqlite_autoindex_users_1")
  display_name     String
  password_hash    String
  role             String            @default("operator")
  created_at       Int               @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at       Int               @default(dbgenerated("floor(extract(epoch from now()))"))
  last_login_at    Int?
  provider         String            @default("local")
  provider_user_id String?
  email            String?
  avatar_url       String?
  is_approved      Int               @default(1)
  approved_by      String?
  approved_at      Int?
  workspace_id     Int               @default(1)
  access_requests  access_requests[]
  user_sessions    user_sessions[]

  @@index([workspace_id], map: "idx_users_workspace_id")
  @@index([email], map: "idx_users_email")
  @@index([provider], map: "idx_users_provider")
  @@index([username], map: "idx_users_username")
}

model webhook_deliveries {
  id                 Int      @id @default(autoincrement())
  webhook_id         Int
  event_type         String
  payload            String
  status_code        Int?
  response_body      String?
  error              String?
  duration_ms        Int?
  created_at         Int      @default(dbgenerated("floor(extract(epoch from now()))"))
  attempt            Int      @default(0)
  next_retry_at      Int?
  is_retry           Int      @default(0)
  parent_delivery_id Int?
  workspace_id       Int      @default(1)
  webhooks           webhooks @relation(fields: [webhook_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workspace_id], map: "idx_webhook_deliveries_workspace_id")
  @@index([next_retry_at], map: "idx_webhook_deliveries_retry", where: raw("next_retry_at IS NOT NULL"))
  @@index([created_at], map: "idx_webhook_deliveries_created_at")
  @@index([webhook_id], map: "idx_webhook_deliveries_webhook_id")
}

model webhooks {
  id                   Int                  @id @default(autoincrement())
  name                 String
  url                  String
  secret               String?
  events               String               @default("[\"*\"]")
  enabled              Int                  @default(1)
  last_fired_at        Int?
  last_status          Int?
  created_by           String               @default("system")
  created_at           Int                  @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at           Int                  @default(dbgenerated("floor(extract(epoch from now()))"))
  consecutive_failures Int                  @default(0)
  workspace_id         Int                  @default(1)
  webhook_deliveries   webhook_deliveries[]

  @@index([workspace_id], map: "idx_webhooks_workspace_id")
  @@index([enabled], map: "idx_webhooks_enabled")
}

model workflow_pipelines {
  id            Int             @id @default(autoincrement())
  name          String
  description   String?
  steps         String          @default("[]")
  created_by    String          @default("system")
  created_at    Int             @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at    Int             @default(dbgenerated("floor(extract(epoch from now()))"))
  use_count     Int             @default(0)
  last_used_at  Int?
  workspace_id  Int             @default(1)
  pipeline_runs pipeline_runs[]

  @@index([workspace_id], map: "idx_workflow_pipelines_workspace_id")
  @@index([name], map: "idx_workflow_pipelines_name")
}

model workflow_templates {
  id              Int     @id @default(autoincrement())
  name            String
  description     String?
  model           String  @default("sonnet")
  task_prompt     String
  timeout_seconds Int     @default(300)
  agent_role      String?
  tags            String?
  created_by      String  @default("system")
  created_at      Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at      Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  last_used_at    Int?
  use_count       Int     @default(0)
  workspace_id    Int     @default(1)

  @@index([workspace_id], map: "idx_workflow_templates_workspace_id")
  @@index([created_by], map: "idx_workflow_templates_created_by")
  @@index([name], map: "idx_workflow_templates_name")
}

model workspaces {
  id              Int               @id @default(autoincrement())
  slug            String            @unique(map: "sqlite_autoindex_workspaces_1")
  name            String
  tenant_id       Int
  created_at      Int               @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at      Int               @default(dbgenerated("floor(extract(epoch from now()))"))
  adapter_configs adapter_configs[]
  tenants         tenants           @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id], map: "idx_workspaces_tenant_id")
  @@index([slug], map: "idx_workspaces_slug")
}
