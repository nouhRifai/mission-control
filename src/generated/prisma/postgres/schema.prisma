generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma/postgres"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model access_requests {
  id               Int     @id @default(autoincrement())
  provider         String  @default("google")
  email            String
  provider_user_id String?
  display_name     String?
  avatar_url       String?
  status           String  @default("pending")
  requested_at     Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  last_attempt_at  Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  attempt_count    Int     @default(1)
  reviewed_by      String?
  reviewed_at      Int?
  review_note      String?
  approved_user_id Int?
  users            users?  @relation(fields: [approved_user_id], references: [id], onUpdate: NoAction)

  @@unique([email, provider], map: "idx_access_requests_email_provider")
  @@index([status], map: "idx_access_requests_status")
}

model activities {
  id           Int     @id @default(autoincrement())
  type         String
  entity_type  String
  entity_id    Int
  actor        String
  description  String
  data         String?
  created_at   Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  workspace_id Int     @default(1)

  @@index([workspace_id], map: "idx_activities_workspace_id")
  @@index([entity_type, entity_id], map: "idx_activities_entity")
  @@index([actor], map: "idx_activities_actor")
  @@index([type], map: "idx_activities_type")
  @@index([created_at], map: "idx_activities_created_at")
}

model adapter_configs {
  id           Int        @id @default(autoincrement())
  workspace_id Int
  framework    String
  config       String?    @default("{}")
  enabled      Int        @default(1)
  created_at   Int        @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at   Int        @default(dbgenerated("floor(extract(epoch from now()))"))
  workspaces   workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([workspace_id, framework], map: "idx_adapter_configs_workspace_framework")
}

model agent_api_keys {
  id           Int     @id @default(autoincrement())
  agent_id     Int
  workspace_id Int     @default(1)
  name         String
  key_hash     String
  key_prefix   String
  scopes       String  @default("[]")
  expires_at   Int?
  revoked_at   Int?
  last_used_at Int?
  created_by   String?
  created_at   Int     @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at   Int     @default(dbgenerated("floor(extract(epoch from now()))"))

  @@unique([workspace_id, key_hash], map: "sqlite_autoindex_agent_api_keys_1")
  @@index([revoked_at], map: "idx_agent_api_keys_revoked_at")
  @@index([expires_at], map: "idx_agent_api_keys_expires_at")
  @@index([workspace_id], map: "idx_agent_api_keys_workspace_id")
  @@index([agent_id], map: "idx_agent_api_keys_agent_id")
}

model agent_trust_scores {
  id                 Int    @id @default(autoincrement())
  agent_name         String
  trust_score        Float  @default(1.0)
  auth_failures      Int    @default(0)
  injection_attempts Int    @default(0)
  rate_limit_hits    Int    @default(0)
  secret_exposures   Int    @default(0)
  successful_tasks   Int    @default(0)
  failed_tasks       Int    @default(0)
  last_anomaly_at    Int?
  workspace_id       Int    @default(1)
  updated_at         Int    @default(dbgenerated("floor(extract(epoch from now()))"))

  @@unique([agent_name, workspace_id], map: "sqlite_autoindex_agent_trust_scores_1")
}

model agents {
  id                 Int                  @id @default(autoincrement())
  name               String               @unique(map: "sqlite_autoindex_agents_1")
  role               String
  session_key        String?              @unique(map: "sqlite_autoindex_agents_2")
  soul_content       String?
  working_memory     String               @default("")
  status             String               @default("offline")
  last_seen          Int?
  last_activity      String?
  created_at         Int                  @default(dbgenerated("floor(extract(epoch from now()))"))
  updated_at         Int                  @default(dbgenerated("floor(extract(epoch from now()))"))
  config             String?
  workspace_id       Int                  @default(1)
  source             String?              @default("manual")
  content_hash       String?
  workspace_path     String?
  direct_connections direct_connections[]

  @@index([source], map: "idx_agents_source")
  @@index([workspace_id], map: "idx_agents_workspace_id")
  @@index([status], map: "idx_agents_status")
  @@index([session_key], map: "idx_agents_session_key")
}

model alert_rules {
